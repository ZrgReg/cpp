/* Использование qr_gen.dll */

// Возвращает номер версии библиотеки.
int  version(void);

// Активация/деактивация библтотеки.
// Вызов функции "execute", автоматически выполняет активацию библиотеки.
void initial(void);
void destroy(void);

// Возвращает количество ошибок.
// Генерирует QR-коды из "text", и сохраняет в файлы с именем "fnme".
// Параметр "xml" содержит данные о тексте и имени файла, имеет вид:
//     <root>
//         <code fnme="{NAME_1}" text="{STRING_1}" />
//         ...
//         <code fnme="{NAME_n}" text="{STRING_n}" />
//     </root>
// Параметр "fnme" задаёт имя и формат изображения (формат определяется по расшитению).
// Параметр "size" задаёт размер QR-кода (в точках).
// Параметр "threads" задаёт количество процессов, на которые будет разбито задание.
// Параметр "mode" задаёт реакцию на обнаружение ошибки генерации/сохранения QR-кода.
//     (mode == 1) => В случае обнаружение ошибки, прерывается выполение задания.
//     (mode == 2) => В случае обнаружение ошибки, задание продолдает выполняться.
int  execute(const char *xml, int size, int threads, int mode);

// Возвращает количество ошибок, возникших при выполнении последнего задания.
int  err_cnt(void);

// Возвращает указатель на массив структур, содержащих информацию об ошибках.
// Структура имеет вид: struct {int error_code; const char *error_text; }
//     (error_code == 1) => Ошибка в структуре XML.
//     (error_code == 2) => Ошибка при генерации QR-кода.
//     (error_code == 3) => Ошибка при описании задачи.
//     (error_code == 4) => Ошибка при сохранении изображения QR-кода.
// Параметр "fmt" определяет кодировку сообщений ("Windows-1251", "UTF-8").
void* err_txt(const char *fmt);
void* err_txt_1251(void); // Сообщения в кодировке cp1251.

/* Допустимые расширения. */

